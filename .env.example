# ── Telegram ──────────────────────────────────────────────────────────────
# Get from @BotFather
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Get from https://my.telegram.org
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Your Telegram user ID (comma-separated for multiple admins)
ADMINS=123456789

# ── Storage ────────────────────────────────────────────────────────────────
DATABASE_PATH=watermark_bot.db
TEMP_DIR=temp
LOGS_DIR=logs

# ── Limits ─────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_GB=1

# ── Watermark defaults ─────────────────────────────────────────────────────
DEFAULT_WATERMARK_TEXT=@YourChannel
DEFAULT_OPACITY=0.7
DEFAULT_SIZE=0.2
DEFAULT_SPEED=80
DEFAULT_FONT_SIZE=40
DEFAULT_COLOR=white
DEFAULT_MODE=moving

# ── Flask port ─────────────────────────────────────────────────────────────
PORT=10000
